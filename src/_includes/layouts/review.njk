---
layout: page.njk
is_review: true
styles:
  internal:
    - reviews.css
image:
  figClasses:
    - picture--block
---

  <div class="content-canvas-item-full content-canvas">
    {{ content | safe }}
  </div>

{% macro reviewItem(review) %}
  <div class="review-item" itemscope itemtype="https://schema.org/Book">
    <div class="review-item--key-data">
      <h3 class="review-item--title heading-v-wide" itemprop="name">
        <a href="{{ review.urls.book }}" rel="noopener noreferrer" target="_blank">{{ review.title }}</a>
        <a class="direct-link visually-hidden" href="#{{ review.title | slug }}" aria-hidden="true">#</a>
      {% if review.audiobook %}
        <em class="small">(audiobook)</em>
      {% endif %}
      </h3>
      {% if review.subtitle %}
      <p class="bold smaller"><em>{{ review.subtitle }}</em></p>
      {% endif %}

      <p class="review-item--author" itemprop="author">
        <em>by {{ review.author }}</em><br/>
        {% if review.author_extras %}
        <em class="small">with {% for extra in review.author_extras %}{{ extra.name }} ({{ extra.role }}){% if not loop.last %}, {% endif %}{% endfor %}</em><br />
        {% endif %}
      </p>
    </div>
    

    {% if review.urls.cover %}
      {% set imagePath = review.urls.cover %}
      {% set imageAlt = [review.title, " book cover"] | join %}
    <a href="{{ review.urls.book }}" rel="noopener noreferrer" target="_blank" class="review-item--cover">{% ImgFigure "", image.figClasses %}![{{ imageAlt }}]({{ imagePath }}){.image-rounded eleventy:widths="100,200" eleventy:formats="webp,jpg" itemprop=image}{% endImgFigure %}</a>
    {% endif %}

    {% if  review.type or review.moods or review.questions %}
    <div class="review-meta content-canvas-item-wide-left">
      {% if review.type %}
      <p class="review-meta--type">
        ({{ review.type }})
      </p>
      {% endif %}
      {% if review.moods %}
      <p class="review-meta--moods">
        <em>{{ review.moods }}</em>
      </p>
      {% endif %}
      {% if review.questions %}
      <ul class="review-meta--character-questions-list">
          <li>
              <strong>Plot- or character-driven?</strong>
              {{ review.questions.driven }}</li>
          <li>
              <strong>Strong character development?</strong>
              {{ review.questions.development }}</li>
          <li>
              <strong>Loveable characters?</strong>
              {{ review.questions.loveable }}</li>
          <li>
              <strong>Diverse cast of characters?</strong>
              {{ review.questions.diverse }}</li>
          <li>
              <strong>Flaws of characters a main focus?</strong>
              {{ review.questions.flaws }}</li>
      </ul>
      {% endif %}
    </div>
    {% endif %}

    {% if review.text %}
    <div class="review-item--text" itemprop="review" itemscope itemtype="https://schema.org/Review">
      <span itemprop="reviewBody">
        {{ review.text | markdown | safe }}
      </span>
      {% if review.rating %}
      <div itemprop="reviewRating">
        {{ review.rating }} ⭐️
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div> 
{% endmacro %}

{% macro reviewItemMini(review) %}
<div class="review-item review-item-mini{% if review.urls.cover %} review-item-mini-with-cover{% endif %} review-key-data" itemscope itemtype="https://schema.org/Book">
  <div class="review-item--key-data">
    <div class="review-item-title" itemprop="name">
      <h3 class="heading-v-wide h4-style">
        <a href="{{ review.urls.book }}" rel="noopener noreferrer" target="_blank">{{ review.title }}</a>
        <a class="direct-link visually-hidden" href="#{{ review.title | slug }}" aria-hidden="true">#</a>
      {% if review.audiobook %}
        <em class="small">(audiobook)</em>
      {% endif %}
      </h3>

      {% if review.subtitle %}
      <p class="review-item-subtitle margin-block-start-nil bold headings-font">— {{ review.subtitle }}</p>
      {% endif %}
    </div>
    <p class="review-item-author margin-block-start-nil" itemprop="author">
      <em>by {{ review.author }}</em><br/>
      {% if review.author_extras %}
      <em class="small">with {% for extra in review.author_extras %}{{ extra.name }} ({{ extra.role }}){% if not loop.last %}, {% endif %}{% endfor %}</em><br />
      {% endif %}
    </p>

    {% if review.reread or review.type%}
    <div class="review-item-meta review-meta">
      {% if review.type %}
      <p class="review-meta--type small">
        ({{ review.type }})
      </p>

      {% if review.reread %}
        <em class="small">(re-read)</em>
      {% endif %}
      {% endif %}

    </div>
    {% endif %}
  </div>
    <div class="review-item--text" itemprop="review" itemscope itemtype="https://schema.org/Review">
      <span itemprop="reviewBody">
      {% if review.text %}
        {{ review.text | markdown | safe }}
      {% endif %}
      </span>
    </div>

    {% if review.urls.cover %}
    <div class="review-item-cover">
      {% set imagePath = review.urls.cover %}
      {% set imageAlt = [review.title, " book cover"] | join %}
      <a href="{{ review.urls.book }}" rel="noopener noreferrer" target="_blank" class="content-canvas-item-wide-right content-canvas-item-right--span-2">{% ImgFigure "", image.figClasses %}![{{ imageAlt }}]({{ imagePath }}){.image-rounded eleventy:widths="100,150" eleventy:formats="webp,jpg" itemprop=image}{% endImgFigure %}</a>
    </div>
    {% endif %}
</div>
{% endmacro %}

  {# {% from 'layouts/macros/reading-review.njk' import readingReview %} #}  

  {% if reviews.top | length %}
    {% if reviews.top.fiction | length %}
      {% Markdown %}
## {{ reviews.top.fiction.title | default("Best Fiction") }}{.content-canvas-item-wide}
      {% endMarkdown %}
      {% for review in reviews.top.fiction.list %}
        {{ reviewItem(review) }}

        {% if not loop.last %}
        <hr>
        {% elif reviews.top.nonFiction | length %}
        <hr>
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if reviews.top.nonFiction | length %}
      {% Markdown %}
## {{ reviews.top.nonFiction.title | default("Best Non-Fiction") }}{.content-canvas-item-wide}
      {% endMarkdown %}
      {% for review in reviews.top.nonFiction.list %}
        {{ reviewItem(review) }}

        {% if not loop.last %}
        <hr>
        {% elif reviews.others | length %}
        <hr>
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if reviews.others | length %}
      {% Markdown %}
## {{ reviews.others.title | default("The Rest") }}{.content-canvas-item-wide}
      {% endMarkdown %}

{% if reviews.others.text | length %}
{% Markdown %}
{{ reviews.others.text }}{.margin-block-vlg}
{% endMarkdown %}
{% endif %}

      {% for month, reviewSet in reviews.others.list | groupby("month") %}
      {% Markdown %}
### {{ month | monthNameFromNum }}{.content-canvas-item-wide .margin-block-vlg .heading-v-wide .h-underline}
      {% endMarkdown %}
        <div class="reviewset reviewset--{{ reviews.reviewSet | tf }} content-canvas-item-wide">
      {% set cls = cycler("odd", "even") %}
        {% for review in reviewSet %}
      <div class="reviewset-item reviewset-item--{{ cls.next() }}">
    {{ reviewItemMini(review) }}
        </div>
        {% endfor %}
    </div>
      {% endfor %}
    {% endif %}
  {% else %}
    {% set reviewsList = reviews.list %}
  {% endif %}

{% if reviewsList %}
{% if reviews.title or reviews.text %}

{% if reviews.title | length %}
<div class="content-canvas-item-wide margin-block-lg">
    {% Markdown %}
## {{ reviews.title }}
    {% endMarkdown %}
  {% endif %}

  {% if reviews.text | length %}
    {% Markdown %}
{{ reviews.text }}
    {% endMarkdown %}
  {% endif %}
</div>
{% endif %}

  {% for month, reviewSet in reviewsList | groupby("month") %}
    {% if month > 0 %}
      {% Markdown %}
### {{ month | monthNameFromNum }}{.content-canvas-item-wide .margin-block-vlg .heading-v-wide .h-underline}
      {% endMarkdown %}
    {% endif %}
    <div class="reviewset reviewset--{{ reviews.reviewSet | tf }}{% if reviews.reviewSet %} content-canvas-item-wide{% endif %}">
      {% set cls = cycler("odd", "even") %}
        {% for review in reviewSet %}
      <div class="reviewset-item reviewset-item--{{ cls.next() }}">
    {{ reviewItemMini(review) }}
        </div>
        {% endfor %}
    </div>
  {% endfor %}
{% endif %}