---
layout: base.njk
list: true
eleventyComputed:
  meta:
    author:
      name: "{{ metadata.author.name }}"
    published: "{{ date | iso8601 }}"
    modified: "{% if changed %}{{ changed | iso8601 }}{% endif %}"
    url: "{{ page.url | htmlBaseUrl }}"
---

	<div class="site-content site-content--zero-top-padding content-canvas">
		
		<div class="site-content{% if pageClass %} {{ pageClass }} {% else %} site-content--surface-teal site-content--surface-dark{% endif %} jumbotron content-canvas-item-full content-canvas">

			{% include "layouts/components/title-bar.njk" %}

		</div>
		{% if content %}
		<div class="site-content content-canvas-item-full content-canvas">
			
			{{ content | safe }}
		</div>
		{% endif %}
		<div class="site-content content-canvas-item-wide">

			{% include "layouts/components/index-list.njk" %}

		</div>

		
    {% if listFooter %}
    <div class="list-footer margin-block-vlg">
      {{ listFooter | markdown | safe }}
    </div>
    {% endif %}

	</div>