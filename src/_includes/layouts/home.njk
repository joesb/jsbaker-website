---
layout: base.njk
section: home
primary: true
hideDescription: true
styles:
  internal:
    - home.css
eleventyComputed:
  meta:
    author:
      name: "{{ metadata.author.name }}"
    published: "{{ date | iso8601 }}"
    modified: "{% if changed %}{{ changed | iso8601 }}{% endif %}"
    url: "{{ page.url | htmlBaseUrl }}"
---

<div class="site-content site-content--zero-top-padding content-canvas">

  <div class="home-layout content-canvas-item-full">

    <div class="home-layout__item home-layout__item--left home-layout__item--dark-cyan">
      <div class="home-layout__item__inner">
        <div class="home-layout__item__inner__content">
          {% include "layouts/components/title-bar.njk" %}

          {{ content | safe  }}
        </div>
      </div>
    </div>

    <div class="home-layout__item home-layout__item--right">
      <div class="home-layout__item__inner">
        <a href="/about/">
        {% image image.path, image.alt, image.class, image.pictureClass.page, 'fetchpriority="high" loading="eager"', "auto", [300, 600] %}
        </a>
      </div>
    </div>

  </div>

  <div class="site-content content-canvas-item-wide">

    {% include "layouts/components/index-list.njk" %}

  </div>
</div>